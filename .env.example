# ============================================
# CODING ENGINE - Environment Configuration
# ============================================

# Application
APP_NAME=coding-engine
APP_ENV=development
DEBUG=true

# ============================================
# REQUIRED for Hybrid Pipeline
# ============================================

# Supermemory (for code pattern memory)
# Get your API key from https://console.supermemory.ai/
SUPERMEMORY_API_KEY=sm_ePqNR5xPgTDdnyP9oF3VWd_QqLFohZBEjhwPRjpEStwaVfbSgMKcapvHLTrIUFxvliPGNcaWQRPssDEWFJIrxoQ

# Hybrid Pipeline Configuration
PIPELINE_MAX_CONCURRENT=5
PIPELINE_MAX_ITERATIONS=3
PIPELINE_SLICE_SIZE=10
PIPELINE_OUTPUT_DIR=./output

# Claude CLI (uses OAuth from 'claude login', no API key needed)
# Make sure you've run: claude login
CLAUDE_CLI_TIMEOUT=300

# ============================================
# OPTIONAL - Only for API Server Mode
# ============================================

# API Server (only if running FastAPI server)
# API_HOST=0.0.0.0
# API_PORT=8000
# API_WORKERS=4

# Database (only if using persistence)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/coding_engine
# DATABASE_POOL_SIZE=20

# Redis (only if using task queue)
# REDIS_URL=redis://localhost:6379/0

# Anthropic API (only if using Agent SDK directly instead of CLI)
# ANTHROPIC_API_KEY=your-api-key-here

# ============================================
# OPTIONAL - Advanced Features
# ============================================

# Git Integration (only if pushing to repo)
# GIT_SERVER_URL=http://localhost:3000
# GIT_USERNAME=coding-engine
# GIT_PASSWORD=coding-engine
# GIT_EMAIL=engine@localhost

# ============================================
# GITHUB - For Orchestrator Git Push (Phase 7)
# ============================================

# GitHub Personal Access Token (PAT)
# Create at: https://github.com/settings/tokens
# Required scopes: repo (Full control of private repositories)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: GitHub username (if different from token owner)
# GITHUB_USERNAME=your-username

# Optional: Default repository settings
GITHUB_DEFAULT_PRIVATE=true

# ============================================
# ORCHESTRATOR - External APIs
# ============================================

# Project-Create API (techstack scaffolding service)
PROJECT_CREATE_API_URL=http://localhost:8087

# Coding Engine Control API (FastAPI server in Docker)
CODING_ENGINE_API_URL=http://localhost:8000

# Docker Sandbox (only if running code in sandbox)
# DOCKER_HOST=unix:///var/run/docker.sock
# SANDBOX_IMAGE=coding-engine/sandbox:latest
# SANDBOX_MEMORY_LIMIT=512m
# SANDBOX_CPU_LIMIT=1.0
# SANDBOX_TIMEOUT=300

# Storage
# ARTIFACT_STORAGE_PATH=/data/artifacts
