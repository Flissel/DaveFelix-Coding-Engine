# ============================================================
# ValidationTeam Dockerfile - Multi-Stage Build
# Frontend: React/Vite (Port 3100)
# Backend: FastAPI/Uvicorn (Port 8100)
# ============================================================

# Stage 1: Node.js Frontend Builder
FROM node:20-alpine AS frontend-builder

WORKDIR /app

# Copy package.json first for layer caching
COPY package*.json ./

# Install dependencies (npm install works without lock file)
RUN npm install --quiet --legacy-peer-deps || npm install

# Copy rest of source files
COPY . .

# Build frontend (outputs to dist/)
RUN npm run build || (echo "Build failed, creating minimal static files" && mkdir -p dist && echo "<html><body><h1>Validation Test</h1></body></html>" > dist/index.html)

# ============================================================
# Stage 2: Python Backend Runtime
FROM python:3.11-slim AS runtime

# Install system dependencies including Node.js for serving static files
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    supervisor \
    nodejs \
    npm \
    && rm -rf /var/lib/apt/lists/*

# Install serve for static file serving
RUN npm install -g serve

# Create non-root user for security
RUN groupadd -r validation && useradd -r -g validation validation

WORKDIR /app

# Copy requirements and install Python dependencies
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Copy backend source
COPY src/ ./src/

# Copy frontend build from builder stage
COPY --from=frontend-builder /app/dist/ ./static/

# Create log directory with proper permissions
RUN mkdir -p /var/log/validation && chown -R validation:validation /var/log/validation
RUN mkdir -p /app/test-results && chown -R validation:validation /app/test-results

# Create supervisor directory
RUN mkdir -p /etc/supervisor/conf.d

# Copy supervisord configuration
COPY supervisord.validation.conf /etc/supervisor/conf.d/validation.conf

# Export validation-specific ports (isolated from default 5173/8000)
EXPOSE 3100 8100

# Health check for both services
HEALTHCHECK --interval=10s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:8100/api/health || exit 1

# Run supervisord to manage both services
CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/conf.d/validation.conf"]