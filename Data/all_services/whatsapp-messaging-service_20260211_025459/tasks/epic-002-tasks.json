    {
      "id": "EPIC-002-API-users-feature",
      "epic_id": "EPIC-002",
      "type": "api_controller",
      "title": "Feature: users (20 endpoints: DELETE, GET, POST, PUT)",
      "description": "Generate the COMPLETE NestJS module for 'users' with ALL layers:\n- Controller (all 20 endpoints)\n- Service (business logic)\n- DTOs (request/response types)\n- Guards (JWT auth where needed)\n- Validators (input validation)\n- Module registration\n\nEndpoints:\n  POST /api/v1/users/{userId}/profile-images \u2014 Upload profile image\n  GET /api/v1/users/{userId}/profile-images/current \u2014 Get current profile image\n  PUT /api/v1/users/{userId}/profile-images/current \u2014 Replace current profile image\n  DELETE /api/v1/users/{userId}/profile-images/current \u2014 Delete current profile image\n  GET /api/v1/users/{userId}/profile \u2014 Get user profile\n  PUT /api/v1/users/{userId}/profile/display-name \u2014 Update display name\n  GET /api/v1/users/{userId}/profile/info-text \u2014 Get profile info text\n  PUT /api/v1/users/{userId}/profile/info-text \u2014 Update profile info text\n  POST /api/v1/users/{userId}/qr-codes \u2014 Generate a new profile QR code\n  GET /api/v1/users/{userId}/qr-codes/{qrCodeId} \u2014 Retrieve a profile QR code\n  GET /api/v1/users/{userId}/presence-visibility \u2014 Get online status visibility setting\n  PUT /api/v1/users/{userId}/presence-visibility \u2014 Update online status visibility setting\n  GET /api/v1/users/{userId}/presence-visibility/allowed-users \u2014 List users allowed to see online status\n  GET /api/v1/users/{userId}/presence-visibility/denied-users \u2014 List users denied to see online status\n  GET /api/v1/users/{userId}/settings/read-receipts \u2014 Get read receipt settings\n  PUT /api/v1/users/{userId}/settings/read-receipts \u2014 Update read receipt settings\n  GET /api/v1/users/{userId}/settings/profile-picture-visibility \u2014 Get profile picture visibility setting\n  PUT /api/v1/users/{userId}/settings/profile-picture-visibility \u2014 Update profile picture visibility setting\n  GET /api/v1/users/{userId}/privacy/infoVisibility \u2014 Get info/status text visibility settings\n  PUT /api/v1/users/{userId}/privacy/infoVisibility \u2014 Update info/status text visibility settings",
      "status": "completed",
      "dependencies": [
        "EPIC-002-CHECKPOINT-schema"
      ],
