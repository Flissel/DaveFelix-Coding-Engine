# Dockerfile für EventFix Agents
FROM python:3.11-slim

WORKDIR /app

# System-Abhängigkeiten installieren
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    postgresql-client \
    curl \
    redis-tools \
    && rm -rf /var/lib/apt/lists/*

# Python-Abhängigkeiten kopieren und installieren
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Protobuf-Dateien kompilieren
COPY proto/ ./proto/
RUN python -m grpc_tools.protoc -I./proto --python_out=. --grpc_python_out=. ./proto/agent_service.proto

# Quellcode kopieren
COPY src/ ./src/
COPY agents/ ./agents/

# Verzeichnisse erstellen
RUN mkdir -p /app/logs /app/tasks

# Port freigeben (für Health Checks)
EXPOSE 8000

# Health Check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import sys; sys.exit(0)"

# Agent starten (wird durch docker-compose gesteuert)
CMD ["python", "-c", "import sys; print('Agent container ready')"]
