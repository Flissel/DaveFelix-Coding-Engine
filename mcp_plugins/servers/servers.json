{
  "comment": "MCP Server Registry - Docker/Linux paths for container execution",
  "grpc_config": {
    "base_port": 50061,
    "port_range": "50061-50090",
    "enabled": true
  },
  "servers": [
    {
      "name": "playwright",
      "active": true,
      "type": "stdio",
      "grpc_port": 50061,
      "command": "npx",
      "args": [
        "--yes",
        "@playwright/mcp@latest",
        "--browser=chromium",
        "--viewport-size=1280,720"
      ],
      "read_timeout_seconds": 120,
      "description": "Playwright MCP - Browser automation, DOM interaction, screenshots"
    },
    {
      "name": "github",
      "active": false,
      "type": "stdio",
      "grpc_port": 50062,
      "command": "npx",
      "args": [
        "--yes",
        "@modelcontextprotocol/server-github"
      ],
      "env_vars": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "env:GITHUB_TOKEN"
      },
      "read_timeout_seconds": 120,
      "description": "GitHub MCP - Repository management, issues, PRs (needs GITHUB_TOKEN)"
    },
    {
      "name": "docker",
      "active": true,
      "type": "stdio",
      "grpc_port": 50063,
      "command": "python",
      "args": [
        "-m",
        "mcp_server_docker"
      ],
      "read_timeout_seconds": 120,
      "description": "Docker MCP - Container operations, compose, logs"
    },
    {
      "name": "desktop",
      "active": false,
      "type": "stdio",
